# ─── Supabase ─────────────────────────────────────────────────────────
# Tomado de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Solo se usa en el servidor (admin client en
# src/lib/supabase/admin.ts). NO exponer al cliente. Lo usa el webhook
# de Venflow para escribir sin RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Venflow ──────────────────────────────────────────────────────────
# Base URL del API REST de Venflow.
VENFLOW_API_BASE=https://api.venflow.app/v1

# Clave privada de Venflow (prefijo pvtk_ en sandbox, pvk_ en producción).
# Solo se usa server-side desde src/lib/venflow/client.ts.
VENFLOW_SECRET_KEY=

# Clave pública de Venflow (prefijo pbtk_ en sandbox, pbk_ en producción).
# Va al bundle del cliente (por el prefijo NEXT_PUBLIC_).
NEXT_PUBLIC_VENFLOW_PUBLIC_KEY=

# ID de la organización en Venflow.
VENFLOW_ORG_ID=

# Secret compartido para validar el header X-Webhook-Secret entrante.
# Debe coincidir con el que configures en el dashboard de Venflow al
# registrar el webhook. Genera uno con: openssl rand -hex 32
VENFLOW_WEBHOOK_SECRET=

# IDs de los planes en Venflow (uno por cadencia). Crea cada plan en
# el dashboard de Venflow y pega aquí su UUID. Solo el mensual es
# obligatorio para que el checkout funcione; los demás se activan
# automáticamente al añadir el ID correspondiente.
VENFLOW_PLAN_MENSUAL_ID=
# VENFLOW_PLAN_TRIMESTRAL_ID=
# VENFLOW_PLAN_SEMESTRAL_ID=
# VENFLOW_PLAN_ANUAL_ID=

# ─── Stripe ───────────────────────────────────────────────────────────
# Clave secreta (sk_test_* en sandbox, sk_live_* en producción). Solo
# server-side, vive en src/lib/stripe/client.ts.
STRIPE_SECRET_KEY=

# Webhook signing secret (whsec_*). Para local: stripe listen --forward-to
# localhost:3000/api/stripe/webhooks lo imprime al arrancar. Para prod:
# Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=

# Price IDs (price_*) — uno por cadencia. Stripe Dashboard → Products →
# cada producto tiene su price asociado.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_QUARTERLY=
STRIPE_PRICE_SEMIANNUAL=
STRIPE_PRICE_YEARLY=
